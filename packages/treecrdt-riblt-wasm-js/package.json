{
  "name": "@treecrdt/riblt-wasm",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "browser": "./dist/browser.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "pkg/**/*",
    "pkg-web/**/*"
  ],
  "scripts": {
    "build:wasm": "wasm-pack build ../../packages/treecrdt-riblt-wasm --target nodejs --out-dir $(pwd)/pkg --release && wasm-pack build ../../packages/treecrdt-riblt-wasm --target web --out-dir $(pwd)/pkg-web --release && rm -f pkg/.gitignore pkg-web/.gitignore",
    "build:ts": "tsc -p tsconfig.json",
    "build": "pnpm run build:wasm && pnpm run build:ts",
    "test": "pnpm run build && vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "typescript": "^5.9.3",
    "vitest": "^1.6.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cybersemics/treecrdt.git",
    "directory": "packages/treecrdt-riblt-wasm-js"
  },
  "bugs": {
    "url": "https://github.com/cybersemics/treecrdt/issues"
  },
  "homepage": "https://github.com/cybersemics/treecrdt#readme",
  "publishConfig": {
    "access": "public"
  }
}
